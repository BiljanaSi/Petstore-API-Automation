    {
      "name": "Find Pets by Status (Sold)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status Code | Verify successful retrieval (200 OK)\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "",
              "const jsonData = pm.response.json();",
              "pm.test(\"Format | Response is an array of pets\", function () {",
              "    pm.expect(jsonData).to.be.an('array');",
              "});",
              "",
              "",
              "pm.test(\"Search Logic | Our Pet ID exists in the 'sold' list\", function () {",
              "    const targetId = pm.environment.get(\"current_pet_id\").toString();",
              "    ",
              "   ",
              "    const found = jsonData.some(pet => pet.id.toString() === targetId);",
              "    ",
              "    pm.expect(found).to.be.true;",
              "});",
              "",
              "",
              "pm.test(\"Filter Integrity | All pets in response must have 'sold' status\", function () {",
              "    jsonData.forEach(function(pet) {",
              "        pm.expect(pet.status).to.eql(\"sold\");",
              "    });",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/pet/findByStatus?status=sold",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "pet",
            "findByStatus"
          ],
          "query": [
            {
              "key": "status",
              "value": "sold"
            }
          ]
        }
      },
      "response": []
    },
