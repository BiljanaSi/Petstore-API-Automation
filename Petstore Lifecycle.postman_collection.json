  },
  "item": [
    {
      "name": "Add New Pet",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status Code | Verify successful pet creation (200 OK)\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const contentType = pm.response.headers.get(\"Content-Type\") || \"\";",
              "const isJson = contentType.includes(\"application/json\");",
              "",
              "pm.test(\"Response | Content-Type is JSON\", function () {",
              "    pm.expect(isJson).to.be.true;",
              "});",
              "",
              "if (isJson) {",
              "    const jsonData = pm.response.json();",
              "",
              "    if (jsonData.id) {",
              "        pm.environment.set(\"current_pet_id\", jsonData.id);",
              "        console.log(\"Saved Pet ID: \" + jsonData.id);",
              "    }",
              "",
              "    pm.test(\"Data Integrity | Verify pet name is Bobi\", function () {",
              "        pm.expect(jsonData.name).to.eql(\"Bobi\");",
              "    });",
              "} else {",
              "    console.warn(\"Non-JSON response received. Content-Type: \" + contentType);",
              "    console.warn(\"Response body: \" + pm.response.text());",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": {{user_pet_id}},\n  \"category\": { \"id\": 1, \"name\": \"Dogs\" },\n  \"name\": \"Bobi\",\n  \"photoUrls\": [\"string\"],\n  \"tags\": [{ \"id\": 1, \"name\": \"vaccinated\" }],\n  \"status\": \"available\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/pet",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "pet"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Pet by ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status Code | Verify pet is found (200 OK)\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "",
              "const jsonData = pm.response.json();",
              "pm.test(\"Data Integrity | ID and Name match the created pet\", function () {",
              "    pm.expect(jsonData.id.toString()).to.eql(pm.environment.get(\"current_pet_id\").toString());",
              "    pm.expect(jsonData.name).to.eql(\"Bobi\");",
              "});",
              "",
              "pm.test(\"Format | Response has category and tags\", function () {",
              "    pm.expect(jsonData).to.have.property('category');",
              "    pm.expect(jsonData.tags).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "protocolProfileBehavior": {
        "disableBodyPruning": true
      },
      "request": {
        "method": "GET",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": {{user_pet_id}},\n  \"category\": { \"id\": 1, \"name\": \"Dogs\" },\n  \"name\": \"Bobi\",\n  \"photoUrls\": [\"string\"],\n  \"tags\": [{ \"id\": 1, \"name\": \"vaccinated\" }],\n  \"status\": \"available\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/pet/{{current_pet_id}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "pet",
            "{{current_pet_id}}"
          ]
        }
      },
      "response": []
