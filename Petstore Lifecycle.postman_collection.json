    {
      "name": "Update Pet Status (Sell)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status Code | Verify successful update (200 OK)\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const jsonData = pm.response.json();",
              "pm.test(\"Business Logic | Status changed to 'sold'\", function () {",
              "    pm.expect(jsonData.status).to.eql(\"sold\");",
              "});",
              "",
              "pm.test(\"Data Integrity | ID remains the same\", function () {",
              "    pm.expect(jsonData.id.toString()).to.eql(pm.environment.get(\"current_pet_id\").toString());",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": {{current_pet_id}},\n  \"name\": \"Bobi\",\n  \"category\": { \"id\": 1, \"name\": \"Dogs\" },\n  \"photoUrls\": [\"https://example.com/bobi.jpg\"],\n  \"tags\": [{\"id\": 1, \"name\": \"vaccinated\"}],\n  \"status\": \"sold\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
